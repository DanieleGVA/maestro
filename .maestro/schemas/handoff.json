{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MAESTRO Inter-Agent Handoff Document",
  "description": "Schema for structured handoff documents between MAESTRO team agents. Every cross-agent handoff MUST conform to this schema.",
  "type": "object",
  "required": ["from", "to", "task_id", "context", "decisions", "open_items", "evidence_refs"],
  "properties": {
    "from": {
      "type": "string",
      "pattern": "^MSTR-\\d{2}$",
      "description": "Agent ID of the sender (e.g. MSTR-02)"
    },
    "to": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^MSTR-\\d{2}$"
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^MSTR-\\d{2}$"
          },
          "minItems": 1
        }
      ],
      "description": "Agent ID(s) of the recipient(s)"
    },
    "task_id": {
      "type": "string",
      "pattern": "^T\\d+\\.\\d+$",
      "description": "Task ID from the task DAG (e.g. T2.1)"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of handoff creation"
    },
    "phase": {
      "type": "string",
      "enum": ["phase_1_foundation", "phase_2_architecture", "phase_3_compliance", "phase_4_implementation", "phase_5_testing", "phase_6_deployment"],
      "description": "Current programme phase"
    },
    "context": {
      "type": "object",
      "required": ["summary", "current_state"],
      "properties": {
        "summary": {
          "type": "string",
          "description": "Brief summary of the work completed and its purpose"
        },
        "current_state": {
          "type": "string",
          "description": "Current state of the deliverable or work stream"
        },
        "dependencies_met": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of dependency task IDs that have been satisfied"
        },
        "assumptions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Assumptions made during the work that the recipient should validate"
        }
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decision", "rationale"],
        "properties": {
          "decision": {
            "type": "string",
            "description": "The decision made"
          },
          "rationale": {
            "type": "string",
            "description": "Why this decision was made"
          },
          "adr_ref": {
            "type": "string",
            "description": "Reference to ADR file in .maestro/decisions/ if applicable"
          },
          "approved_by": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Agent IDs that approved this decision"
          }
        }
      },
      "description": "Decisions made during this work that affect the recipient"
    },
    "open_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item", "owner", "priority"],
        "properties": {
          "item": {
            "type": "string",
            "description": "Description of the open item"
          },
          "owner": {
            "type": "string",
            "description": "Agent ID responsible for resolving this"
          },
          "priority": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "due_by_task": {
            "type": "string",
            "description": "Task ID by which this must be resolved"
          }
        }
      },
      "description": "Items that remain unresolved and need attention from the recipient"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "path"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["adr", "code", "test_result", "document", "schema", "diagram", "dpia", "audit_log"],
            "description": "Type of evidence"
          },
          "path": {
            "type": "string",
            "description": "File path relative to workspace root"
          },
          "description": {
            "type": "string",
            "description": "Brief description of what this evidence shows"
          }
        }
      },
      "description": "References to evidence files that support this handoff"
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "path", "status"],
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["draft", "review", "approved", "final"]
          }
        }
      },
      "description": "List of deliverable files produced"
    }
  },
  "additionalProperties": false
}
